# Unify coding style across editors and IDEs.
# Based on WordPress core .editorconfig.
# See https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab

[*.{yml,yaml,neon}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{json,lock}]
indent_style = space
indent_size = 4
